generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_URL_NON_POOLING")
}

model Student {
  id                 String       @id @default(cuid())
  firstName          String
  lastName           String
  language           String
  status             String
  lastSeen           DateTime?
  email              String?
  phone              String?
  address            String?
  languageConfidence String?      @default("Auto-detected")
  notes              String?
  
  // Class Context
  classCode          String?
  teacherName        String?
  school             String?
  
  // POP-Risk Tracking
  absenceDays        Int          @default(0)
  isPopRisk          Boolean      @default(false)
  popRiskReason      String?
  
  // Team Collaboration
  activeWorkerId     String?
  activeWorkerName   String?
  
  // Outreach Scheduling
  scheduledOutreach  DateTime?

  auditEntries       AuditEntry[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model AuditEntry {
  id          String   @id @default(cuid())
  timestamp   DateTime @default(now())
  actor       String
  action      String
  studentId   String?
  studentName String?
  details     String
  type        String
  student     Student? @relation(fields: [studentId], references: [id])
}

model Setting {
  id    String @id
  value String
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String?
  role          String    @default("EDUCATOR")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
